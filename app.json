{
  "expo": {
    "name": "Sprig",
    "slug": "sprig",
    "version": "1.9.3",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sprig",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mousewerk.sprig",
      "infoPlist": {
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#EAF1EC",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.mousewerk.sprig",
      "versionCode": 28,
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "category": ["DEFAULT"],
          "data": [
            {
              "scheme": "content",
              "mimeType": "application/pdf"
            },
            {
              "scheme": "file",
              "mimeType": "application/pdf"
            },
            {
              "scheme": "content",
              "mimeType": "text/csv"
            },
            {
              "scheme": "file",
              "mimeType": "text/csv"
            },
            {
              "scheme": "content",
              "mimeType": "text/comma-separated-values"
            },
            {
              "scheme": "file",
              "mimeType": "text/comma-separated-values"
            },
            {
              "scheme": "content",
              "mimeType": "application/octet-stream"
            },
            {
              "scheme": "file",
              "mimeType": "application/octet-stream"
            },
            {
              "scheme": "content",
              "mimeType": "application/zip"
            },
            {
              "scheme": "file",
              "mimeType": "application/zip"
            }
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#EAF1EC",
          "dark": {
            "backgroundColor": "#EAF1EC"
          }
        }
      ],
      "expo-sqlite",
      "expo-audio",
      "@react-native-community/datetimepicker",
      "expo-asset",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "808f4cf6-c7b4-485f-953f-e168c5a3e42a"
      }
    }
  }
}
